generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Service {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  shortDesc       String
  longDesc        String   @db.Text
  imageUrl        String?
  icon            String?
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, order])
}

model Event {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  summary         String
  description     String    @db.Text
  date            DateTime?
  location        String?
  imageUrl        String?
  galleryUrls     String[]  @default([])
  category        String?
  registrationUrl String?
  isFeatured      Boolean   @default(false)
  isActive        Boolean   @default(true)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, date])
}

model NewsPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String
  body            String    @db.Text
  imageUrl        String?
  author          String?
  publishedAt     DateTime?
  isPublished     Boolean   @default(false)
  metaTitle       String?
  metaDescription String?
  tags            String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isPublished, publishedAt])
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String
  caption   String?
  imageUrl  String
  category  String   @default("General")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, category, order])
}

model TeamMember {
  id             String   @id @default(cuid())
  name           String
  role           String
  bio            String?  @db.Text
  qualifications String?
  experience     String?
  imageUrl       String?
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  socialLinks    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, order])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  age       String?
  phone     String
  email     String?
  program   String?
  message   String?  @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
