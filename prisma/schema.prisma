generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  role         String   @default("owner")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Service {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  shortDesc       String
  longDesc        String   @db.Text
  imageUrl        String?
  icon            String?
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, order])
}

model Event {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  summary         String
  description     String    @db.Text
  date            DateTime?
  location        String?
  imageUrl        String?
  galleryUrls     String[]  @default([])
  category        String?
  registrationUrl String?
  isFeatured      Boolean   @default(false)
  isActive        Boolean   @default(true)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, date])
}

model NewsPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String
  body            String    @db.Text
  imageUrl        String?
  author          String?
  publishedAt     DateTime?
  isPublished     Boolean   @default(false)
  metaTitle       String?
  metaDescription String?
  tags            String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isPublished, publishedAt])
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String
  caption   String?
  imageUrl  String
  category  String   @default("General")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, category, order])
}

model TeamMember {
  id             String   @id @default(cuid())
  name           String
  role           String
  bio            String?  @db.Text
  qualifications String?
  experience     String?
  imageUrl       String?
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  socialLinks    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, order])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  age       String?
  phone     String
  email     String?
  program   String?
  message   String?  @db.Text
  isRead    Boolean  @default(false)
  label     String   @default("new") // new | lead | followup | scam | closed
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
  @@index([label])
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// Central registry of every Cloudinary asset — powers the Media Library
model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  publicId  String?
  filename  String
  alt       String?
  width     Int?
  height    Int?
  bytes     Int?
  format    String?
  folder    String?
  usedOn    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

/// Open roles for the Careers page
model JobPosting {
  id          String   @id @default(cuid())
  title       String
  type        String?  // Full-time | Part-time | Contract | Internship
  location    String?
  description String   @db.Text
  applyUrl    String?
  isOpen      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isOpen, order])
}

/// Managed list of gallery categories (replaces the hardcoded list)
model GalleryCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([order])
}

/// Training venues shown on the Location page — one primary academy + extras.
/// `mapUrl` is the raw Google Maps share link (used for "Get Directions");
/// `embedUrl` is the iframe src auto-built from it on save.
model Venue {
  id        String   @id @default(cuid())
  name      String
  address   String?  @db.Text
  mapUrl    String   @db.Text
  embedUrl  String?  @db.Text
  lat       Float?
  lng       Float?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}

/// Video reel entries for the Gallery page (replaces "coming soon")
model GalleryVideo {
  id        String   @id @default(cuid())
  title     String?
  url       String
  isEnabled Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([isEnabled, order])
}
