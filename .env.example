# --- Required ---
# Postgres connection string (Railway will provide DATABASE_URL automatically when you add Postgres plugin)
DATABASE_URL="postgresql://user:password@localhost:5432/norvex"

# Public site URL (used for canonical, sitemap, OG)
NEXT_PUBLIC_SITE_URL="https://norvexsports.com"

# Admin bootstrap (used by seed). Change immediately after first deploy.
ADMIN_EMAIL="admin@norvexsports.com"
ADMIN_PASSWORD="ChangeMe!2026"

# Session secret (generate with: openssl rand -base64 32)
SESSION_SECRET="please-change-this-to-a-long-random-string-min-32-chars"

# --- Optional ---
# Cloudinary (enables direct image uploads from admin panel; otherwise paste URLs)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Contact info shown on the site (overrides DB defaults if set)
NEXT_PUBLIC_PHONE="+91 00000 00000"
NEXT_PUBLIC_EMAIL="info@norvexsports.com"
NEXT_PUBLIC_WHATSAPP="919000000000"

# SEO / verification
NEXT_PUBLIC_GA_ID=""
GOOGLE_SITE_VERIFICATION=""

# Netlify CLI auth token (legacy — project deploys to Vercel)
NETLIFY_AUTH_TOKEN=""

# Vercel CLI auth token (create at https://vercel.com/account/tokens)
# CLI-only; never imported by app code.
VERCEL_TOKEN=""
